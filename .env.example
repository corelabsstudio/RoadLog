# ── 실행 환경 ──────────────────────────────────────────
# development = 로컬 / production = 공개 서버 (약한 비밀키면 기동 거부)
APP_ENV=development

# 세션용 시크릿 (32자 이상 난수 권장)
# python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-to-a-long-random-string

# CORS 허용 출처 (운영: 실제 도메인만, 여러 개는 쉼표)
# 예: https://roadlog.example.com,https://www.roadlog.example.com
ALLOWED_ORIGINS=*

# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── Supabase (선택 — 미설정 시 로컬 JSON 폴백) ───────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 관리자 (운영에서는 반드시 강한 값으로 변경) ───────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@roadlog.local

# ── 결제 링크 (토스·포트원 등 실제 URL) ───────────────────
PRO_PAYMENT_URL=https://your-payment-link.example.com
ENTERPRISE_PAYMENT_URL=https://your-payment-link.example.com

# 결제 없이 /api/billing/upgrade 로 플랜 변경 (운영은 반드시 false)
ALLOW_DEMO_BILLING_UPGRADE=false

# ── 문의 ───────────────────────────────────────────────
CONTACT_EMAIL=corelabs.studio@gmail.com
CONTACT_FORM_URL=https://docs.google.com/forms/d/e/xxxxxxxx/viewform

# ── Google AdSense (Free 결과 하단, 선택) ────────────────
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
ADSENSE_SLOT=xxxxxxxxxx
