# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (선택 — 미설정 시 로컬 JSON 폴백)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 관리자 (기본: admin / admin123)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Pro / Enterprise 결제 링크 (토스·포트원 등 실제 결제 URL)
PRO_PAYMENT_URL=https://your-payment-link.example.com
ENTERPRISE_PAYMENT_URL=https://your-payment-link.example.com

# 결제 없이 /api/billing/upgrade 로 플랜 변경 (로컬 데모 전용, 운영은 false)
ALLOW_DEMO_BILLING_UPGRADE=false

# Google AdSense (Free 사용자 결과 하단 전용)
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
ADSENSE_SLOT=xxxxxxxxxx

# 앱 시크릿 (세션 토큰용)
APP_SECRET=change-me-to-a-long-random-string
