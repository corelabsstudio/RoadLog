# development = 로컬 / production = 공개 서버
APP_ENV=development

# 세션용 시크릿 (32자 이상 난수 권장)
# python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-to-a-long-random-string

# CORS 허용 출처 (운영: 실제 도메인만, 여러 개는 쉼표)
# 예: https://roadlog.co.kr
ALLOWED_ORIGINS=*

# OpenAI (정식 런칭 필수 — 없으면 규칙 초안)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Supabase (선택 — 미설정 시 로컬 JSON. 운영은 연결 권장)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 관리자 (소스에 비밀번호를 두지 마세요. 운영에서 반드시 강한 값)
ADMIN_USERNAME=your-admin-id
ADMIN_PASSWORD=use-a-strong-password
ADMIN_EMAIL=admin@example.com

# 결제 링크 (토스/포트원 등 실제 URL. 플레이스홀더면 문의 플로우)
PRO_PAYMENT_URL=
ENTERPRISE_PAYMENT_URL=

# 결제 없이 /api/billing/upgrade 로 플랜 변경 (운영은 반드시 false)
ALLOW_DEMO_BILLING_UPGRADE=false

# 문의
CONTACT_EMAIL=corelabs.studio@gmail.com
CONTACT_FORM_URL=

# 사업자 고지 (푸터 — 비우면 해당 줄 숨김)
BUSINESS_NAME=코어랩스
BUSINESS_OWNER=
BUSINESS_REG_NO=
BUSINESS_ADDRESS=
MAIL_ORDER_REG_NO=

# Google AdSense (Free 결과 하단, 선택)
ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
ADSENSE_SLOT=xxxxxxxxxx
